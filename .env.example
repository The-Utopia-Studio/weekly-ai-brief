# Copy this to `.env` and fill in real values. NEVER commit `.env`.

# Slack incoming webhook for the brief channel.
# Create one at https://api.slack.com/apps → New App → Incoming Webhooks.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME/PLEASE

# xAI Grok API key (used for synthesis + X/Twitter search).
# Get one at https://console.x.ai/.
XAI_API_KEY=xai-REPLACE_ME

# Path to your local last30days skill install.
# Standard install path via `npx skills add mvanhorn/last30days-skill`:
LAST30DAYS_PATH=/Users/YOU/.agents/skills/last30days

# Path to last30days config (where SCRAPECREATORS_API_KEY lives).
# Created during last30days first-run setup.
LAST30DAYS_ENV=/Users/YOU/.config/last30days/.env
